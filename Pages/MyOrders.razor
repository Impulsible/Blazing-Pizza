@page "/myorders"
@inject NavigationManager NavigationManager

<div class="myorders-container">
    <h1 class="myorders-title">📋 My Orders</h1>
    
    @if (orders.Count == 0)
    {
        <div class="empty-orders">
            <p style="font-size: 18px; margin-bottom: 15px;">You haven't placed any orders yet.</p>
            <button class="track-btn" @onclick="GoToMenu">🍕 Order Some Pizza</button>
        </div>
    }
    else
    {
        <div class="orders-list">
            @foreach (var order in orders)
            {
                <div class="order-card">
                    <div class="order-header">
                        <div>
                            <span class="order-id">Order #@order.Id</span>
                            <div class="order-date">📅 @order.Date</div>
                        </div>
                        <div class="order-status @GetStatusClass(order.Status)">
                            @order.Status
                        </div>
                    </div>
                    
                    <div class="order-details">
                        <div class="order-items-count">
                            🍕 Items: <strong>@order.ItemCount</strong>
                        </div>
                        <div class="order-total-price">
                            Total: ₦@order.Total.ToString("N0")
                        </div>
                    </div>
                    
                    <div style="text-align: right;">
                        <!-- This is the important link - uses route parameter -->
                        <button class="track-btn" @onclick="() => ViewOrder(order.Id)">
                            Track Order →
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .myorders-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 40px;
    }
    
    .myorders-title {
        font-size: 28px;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 30px;
        padding-bottom: 15px;
        border-bottom: 3px solid #e67e22;
    }
    
    .orders-list {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    
    .order-card {
        background: white;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border: 1px solid #f0f0f0;
        transition: all 0.3s;
    }
    
    .order-card:hover {
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    }
    
    .order-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 15px;
    }
    
    .order-id {
        font-size: 20px;
        font-weight: 700;
        color: #1a1a2e;
    }
    
    .order-date {
        color: #6c757d;
        font-size: 14px;
    }
    
    .order-status {
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 600;
    }
    
    .status-delivered {
        background: #d4edda;
        color: #155724;
    }
    
    .status-progress {
        background: #fff3cd;
        color: #856404;
    }
    
    .status-preparing {
        background: #cce5ff;
        color: #004085;
    }
    
    .order-details {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 20px;
        padding: 15px 0;
        border-top: 1px solid #e9ecef;
        border-bottom: 1px solid #e9ecef;
    }
    
    .order-total-price {
        font-size: 22px;
        font-weight: 800;
        color: #e67e22;
    }
    
    .track-btn {
        background: #e67e22;
        color: white;
        border: none;
        padding: 10px 24px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }
    
    .track-btn:hover {
        background: #d35400;
        transform: translateY(-2px);
    }
    
    .empty-orders {
        text-align: center;
        padding: 80px;
        background: #f8f9fa;
        border-radius: 16px;
    }
</style>

@code {
    private List<OrderDisplay> orders = new();

    protected override void OnInitialized()
    {
        orders = new List<OrderDisplay>
        {
            new OrderDisplay { Id = 1001, Date = DateTime.Now.AddDays(-2).ToString("MMMM dd, yyyy"), ItemCount = 2, Total = 27998, Status = "Delivered" },
            new OrderDisplay { Id = 1002, Date = DateTime.Now.AddDays(-1).ToString("MMMM dd, yyyy"), ItemCount = 3, Total = 44997, Status = "On the Way" },
            new OrderDisplay { Id = 1003, Date = DateTime.Now.ToString("MMMM dd, yyyy"), ItemCount = 1, Total = 14985, Status = "Preparing" },
        };
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Delivered" => "status-delivered",
            "On the Way" => "status-progress",
            "Preparing" => "status-preparing",
            _ => ""
        };
    }

    private void GoToMenu()
    {
        NavigationManager.NavigateTo("/");
    }

    private void ViewOrder(int orderId)
    {
        // This uses the route parameter!
        NavigationManager.NavigateTo($"/myorders/{orderId}");
    }

    private class OrderDisplay
    {
        public int Id { get; set; }
        public string Date { get; set; } = "";
        public int ItemCount { get; set; }
        public decimal Total { get; set; }
        public string Status { get; set; } = "";
    }
}