@page "/specials"
@using BlazingPizza.Data
@inject PizzaService PizzaService
@inject NavigationManager NavigationManager

<h2 style="color: #e67e22; margin-bottom: 30px;">🍕 Our Pizza Menu</h2>

@if (specials == null)
{
    <p>Loading pizzas...</p>
}
else if (specials.Count == 0)
{
    <p>No pizzas available.</p>
}
else
{
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
        @foreach (var pizza in specials)
        {
            <div style="border: 1px solid #ddd; border-radius: 10px; overflow: hidden; background: white; box-shadow: 0 2px 5px rgba(0,0,0,0.1); cursor: pointer; transition: transform 0.3s;"
                 @onclick="() => GoToPizza(pizza.Id)">
                <div style="height: 180px; background: linear-gradient(135deg, #667eea, #764ba2); display: flex; align-items: center; justify-content: center;">
                    <span style="font-size: 60px;">🍕</span>
                </div>
                <div style="padding: 15px;">
                    <h3>@pizza.Name</h3>
                    <p style="color: #666;">@pizza.Description</p>
                    <p style="font-size: 24px; color: #e67e22; font-weight: bold;">
                        ₦@(pizza.BasePrice * 1500).ToString("N0")
                    </p>
                </div>
            </div>
        }
    </div>
}

<style>
    .pizza-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 15px rgba(0,0,0,0.2);
    }
</style>

@code {
    private List<PizzaSpecial> specials = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            specials = await PizzaService.GetPizzasAsync();
        }
        catch
        {
            specials = new List<PizzaSpecial>();
        }
    }

    private void GoToPizza(int id)
    {
        NavigationManager.NavigateTo($"/pizza/{id}");
    }
}