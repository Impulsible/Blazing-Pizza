@page "/myorders/{orderId:int}"
@inject NavigationManager NavigationManager
@inject HttpClient HttpClient

<div class="order-detail-container">
    @if (invalidOrder)
    {
        <div class="order-not-found">
            <h2>Order not found</h2>
            <p>We're sorry but this order no longer exists.</p>
            <button class="btn-back" @onclick="GoToMyOrders">← Back to My Orders</button>
        </div>
    }
    else if (currentOrder == null)
    {
        <div class="order-loading">
            <p>Loading order details...</p>
        </div>
    }
    else
    {
        <div class="order-detail-card">
            <div class="order-detail-header">
                <h2>Order placed @currentOrder.Date</h2>
                <span class="order-status-badge @GetStatusClass(currentOrder.Status)">
                    @currentOrder.Status
                </span>
            </div>
            
            <div class="order-detail-body">
                <h3>Items:</h3>
                <div class="order-items-list">
                    @foreach (var pizza in currentOrder.Items)
                    {
                        <div class="order-detail-item">
                            <div class="item-name">
                                <strong>@pizza.Name</strong>
                            </div>
                            <div class="item-price">
                                ₦@pizza.Price.ToString("N0")
                            </div>
                        </div>
                    }
                </div>
                
                <div class="order-detail-total">
                    <span>Total:</span>
                    <strong>₦@currentOrder.Total.ToString("N0")</strong>
                </div>
            </div>
            
            <button class="btn-back" @onclick="GoToMyOrders">← Back to My Orders</button>
        </div>
    }
</div>

<style>
    .order-detail-container {
        max-width: 800px;
        margin: 40px auto;
        padding: 20px;
    }
    
    .order-detail-card {
        background: white;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }
    
    .order-detail-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        padding-bottom: 20px;
        border-bottom: 2px solid #e9ecef;
        margin-bottom: 20px;
    }
    
    .order-detail-header h2 {
        margin: 0;
        font-size: 20px;
        color: #1a1a2e;
    }
    
    .order-status-badge {
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 600;
    }
    
    .status-delivered {
        background: #d4edda;
        color: #155724;
    }
    
    .status-progress {
        background: #fff3cd;
        color: #856404;
    }
    
    .status-preparing {
        background: #cce5ff;
        color: #004085;
    }
    
    .order-detail-body h3 {
        margin-bottom: 15px;
        color: #1a1a2e;
    }
    
    .order-items-list {
        margin-bottom: 20px;
    }
    
    .order-detail-item {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid #e9ecef;
    }
    
    .item-name {
        font-size: 15px;
    }
    
    .item-price {
        font-weight: bold;
        color: #e67e22;
    }
    
    .order-detail-total {
        display: flex;
        justify-content: space-between;
        padding: 15px 0;
        border-top: 2px solid #e9ecef;
        font-size: 18px;
        margin-top: 10px;
    }
    
    .btn-back {
        background: #6c757d;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        cursor: pointer;
        margin-top: 20px;
        transition: all 0.3s;
    }
    
    .btn-back:hover {
        background: #5a6268;
    }
    
    .order-not-found {
        text-align: center;
        padding: 60px;
        background: white;
        border-radius: 16px;
    }
    
    .order-loading {
        text-align: center;
        padding: 60px;
    }
</style>

@code {
    [Parameter] 
    public int OrderId { get; set; }

    private OrderDetailData currentOrder;
    private bool invalidOrder = false;

    protected override void OnParametersSet()
    {
        LoadOrder();
    }

    private void LoadOrder()
    {
        var sampleOrders = new Dictionary<int, OrderDetailData>
        {
            { 1001, new OrderDetailData 
                { 
                    Id = 1001, 
                    Date = DateTime.Now.AddDays(-2).ToString("MMMM dd, yyyy"), 
                    Status = "Delivered", 
                    Total = 27998,
                    Items = new List<OrderItemData>
                    {
                        new OrderItemData { Name = "12\" Classic Pepperoni", Price = 14985 },
                        new OrderItemData { Name = "12\" Basic Cheese Pizza", Price = 13013 }
                    }
                } 
            },
            { 1002, new OrderDetailData 
                { 
                    Id = 1002, 
                    Date = DateTime.Now.AddDays(-1).ToString("MMMM dd, yyyy"), 
                    Status = "On the Way", 
                    Total = 44997,
                    Items = new List<OrderItemData>
                    {
                        new OrderItemData { Name = "12\" Buffalo Chicken", Price = 19125 },
                        new OrderItemData { Name = "12\" The Baconatorizor", Price = 17985 },
                        new OrderItemData { Name = "12\" Classic Pepperoni", Price = 14985 }
                    }
                } 
            },
            { 1003, new OrderDetailData 
                { 
                    Id = 1003, 
                    Date = DateTime.Now.ToString("MMMM dd, yyyy"), 
                    Status = "Preparing", 
                    Total = 14985,
                    Items = new List<OrderItemData>
                    {
                        new OrderItemData { Name = "12\" Classic Pepperoni", Price = 14985 }
                    }
                } 
            }
        };

        if (sampleOrders.ContainsKey(OrderId))
        {
            currentOrder = sampleOrders[OrderId];
            invalidOrder = false;
        }
        else
        {
            currentOrder = null;
            invalidOrder = true;
        }
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Delivered" => "status-delivered",
            "On the Way" => "status-progress",
            "Preparing" => "status-preparing",
            _ => ""
        };
    }

    private void GoToMyOrders()
    {
        NavigationManager.NavigateTo("/myorders");
    }

    private class OrderDetailData
    {
        public int Id { get; set; }
        public string Date { get; set; } = "";
        public string Status { get; set; } = "";
        public decimal Total { get; set; }
        public List<OrderItemData> Items { get; set; } = new();
    }

    private class OrderItemData
    {
        public string Name { get; set; } = "";
        public decimal Price { get; set; }
    }
}