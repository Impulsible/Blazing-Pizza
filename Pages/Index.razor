@page "/"
@using BlazingPizza.Data
@using BlazingPizza.Services
@inject PizzaService PizzaService
@inject OrderState OrderState
@inject NavigationManager NavigationManager

<!-- Pizza Grid - 3 Columns -->
<div class="pizza-grid-container">
    @if (specials == null)
    {
        <p>Loading pizzas...</p>
    }
    else
    {
        <div class="pizza-grid-3cols">
            @foreach (var pizza in specials)
            {
                <div class="pizza-card" @onclick="() => AddToOrder(pizza)">
                    <div class="pizza-image">
                        <img src="@pizza.ImageUrl" alt="@pizza.Name" />
                    </div>
                    <div class="pizza-info">
                        <div class="pizza-name">@pizza.Name.ToUpper()</div>
                        <div class="pizza-description">@pizza.Description</div>
                        <div class="pizza-price">₦@((pizza.BasePrice * 1500).ToString("N0"))</div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<PizzaSpecial> specials = new();
    private Order order => OrderState.Order;

    protected override async Task OnInitializedAsync()
    {
        specials = await PizzaService.GetPizzasAsync();
    }

    private void AddToOrder(PizzaSpecial special)
    {
        var pizza = new Pizza
        {
            Special = special,
            SpecialId = special.Id,
            Size = 12,
            Toppings = new List<PizzaTopping>()
        };
        OrderState.Order.Pizzas.Add(pizza);
    }
}