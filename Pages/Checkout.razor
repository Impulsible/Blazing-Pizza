@page "/checkout"
@layout CheckoutLayout
@inject HttpClient HttpClient
@inject NavigationManager NavigationManager

<h2 style="color: #e67e22; margin-bottom: 20px;">🛒 Review Your Order</h2>

@if (cartItems.Count == 0)
{
    <div style="text-align: center; padding: 50px; background: #f9f9f9; border-radius: 10px;">
        <p>Your cart is empty!</p>
        <a href="/specials" style="background: #e67e22; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; display: inline-block; margin-top: 10px;">
            Browse Menu
        </a>
    </div>
}
else
{
    <div style="background: white; border-radius: 10px; overflow: hidden; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
        @foreach (var item in cartItems)
        {
            <div style="border-bottom: 1px solid #eee; padding: 15px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <strong>🍕 @item.Name</strong>
                        <div style="font-size: 12px; color: #666;">@item.Description</div>
                    </div>
                    <div>
                        <span style="color: #e67e22; font-weight: bold;">₦@item.Price.ToString("N2")</span>
                    </div>
                </div>
            </div>
        }
        
        <div style="background: #f9f9f9; padding: 20px; text-align: right;">
            <h3>Total: <span style="color: #e67e22;">₦@GetTotal().ToString("N2")</span></h3>
        </div>
    </div>
    
    <div style="margin-top: 30px; text-align: center;">
        <button class="btn btn-warning" @onclick="PlaceOrder" style="background: #e67e22; border: none; padding: 12px 40px; font-size: 18px; color: white; border-radius: 8px; cursor: pointer;">
            📦 Place Order
        </button>
    </div>
}

@code {
    private List<CartItem> cartItems = new();
    private bool isSubmitting = false;

    protected override void OnInitialized()
    {
        LoadCart();
    }

    private void LoadCart()
    {
        cartItems = new List<CartItem>
        {
            new CartItem { Name = "Margherita", Description = "Fresh mozzarella, basil", Price = 12999.00m },
            new CartItem { Name = "Pepperoni", Description = "Classic pepperoni", Price = 14999.00m }
        };
    }

    private decimal GetTotal()
    {
        return cartItems.Sum(x => x.Price);
    }

    private async Task PlaceOrder()
    {
        if (isSubmitting) return;
        
        isSubmitting = true;
        
        try
        {
            await Task.Delay(1000);
            cartItems.Clear();
            NavigationManager.NavigateTo("/myorders");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private class CartItem
    {
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; }
    }
}